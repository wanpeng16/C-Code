{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build Active C++ File",
      "type": "process",
      "command": "g++",
      "args": [
        "-std=c++17",
        "-g",
        "-O0",
        "-Wall",
        "-Wextra",
        "-Wpedantic",
        "${file}",
        "-o",
        "${fileDirname}/${fileBasenameNoExtension}.exe"
      ],
      "options": {
        "cwd": "${fileDirname}"
      },
      "problemMatcher": ["$gcc"],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}